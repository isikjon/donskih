# ─── App ───
APP_NAME=donskih-api
APP_ENV=production
DEBUG=false
SECRET_KEY=change-me-to-random-64-chars

# ─── Database ───
POSTGRES_USER=donskih
POSTGRES_PASSWORD=change-me
POSTGRES_DB=donskih
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ─── Redis ───
REDIS_URL=redis://redis:6379/0

# ─── JWT ───
JWT_SECRET_KEY=change-me-to-another-random-64-chars
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Telegram Gateway ───
TELEGRAM_GATEWAY_TOKEN=your-gateway-api-token
TELEGRAM_GATEWAY_URL=https://gatewayapi.telegram.org

# ─── Telegram Bot (Login Widget) ───
TELEGRAM_BOT_TOKEN=your-bot-token

# ─── Admin (content CRUD) ───
ADMIN_SECRET_KEY=change-me-admin-secret-key
HLS_UPLOAD_DIR=/var/www/hls/uploads
HLS_PUBLIC_BASE_URL=https://donskih-cdn.ru/hls/uploads
UPLOAD_MAX_SIZE_MB=1024

# ─── Rate Limiting ───
RATE_LIMIT_SEND_CODE_PER_IP=30/10min
RATE_LIMIT_SEND_CODE_PER_PHONE=5/10min
RATE_LIMIT_VERIFY_CODE_MAX_ATTEMPTS=5
VERIFICATION_CODE_TTL_SECONDS=300
VERIFICATION_COOLDOWN_SECONDS=30
